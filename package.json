{
  "name": "@locflamedia/agentic-vault",
  "version": "0.1.2",
  "description": "Local-first MCP server and CLI for AI-managed Obsidian-compatible knowledge vaults.",
  "type": "module",
  "bin": {
    "agentic-vault": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm typecheck",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.17.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "main": "./dist/cli/index.js",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obsidian",
    "markdown",
    "knowledge-base",
    "ai-agent",
    "local-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/locflamedia/agentic-vault.git"
  },
  "bugs": {
    "url": "https://github.com/locflamedia/agentic-vault/issues"
  },
  "homepage": "https://github.com/locflamedia/agentic-vault#readme",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.26.1"
}
